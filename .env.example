# ===========================================
# Bolo-Man Environment Configuration
# ===========================================

# App
NODE_ENV=development
APP_PORT=3000
APP_URL=http://localhost:3000
ADMIN_URL=http://localhost:5173

# Database
DATABASE_URL=postgresql://boloman:boloman_secret@localhost:5432/boloman?schema=public

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# OTP
OTP_EXPIRY_MINUTES=5

# SMS Provider (e.g., Twilio or local SMS gateway)
SMS_PROVIDER=twilio
SMS_API_KEY=
SMS_API_SECRET=
SMS_FROM_NUMBER=

# Payment Gateways
# MTN MoMo Cameroon
MOMO_BASE_URL=https://sandbox.momodeveloper.mtn.com
MOMO_SUBSCRIPTION_KEY=
MOMO_API_USER=
MOMO_API_KEY=
MOMO_ENVIRONMENT=sandbox
MOMO_CURRENCY=XAF
MOMO_CALLBACK_URL=http://localhost:3000/payments/webhooks/momo

# Orange Money Cameroon
ORANGE_MONEY_BASE_URL=https://api.orange.com
ORANGE_MONEY_CLIENT_ID=
ORANGE_MONEY_CLIENT_SECRET=
ORANGE_MONEY_MERCHANT_KEY=
ORANGE_MONEY_CALLBACK_URL=http://localhost:3000/payments/webhooks/orange

# Flutterwave (Card Payments)
FLUTTERWAVE_BASE_URL=https://api.flutterwave.com/v3
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_ENCRYPTION_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=
FLUTTERWAVE_CALLBACK_URL=http://localhost:3000/payments/webhooks/flutterwave

# Push Notifications (Firebase)
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# Email (SendGrid)
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@boloman.cm

# Sentry
SENTRY_DSN=

# Default Country
DEFAULT_COUNTRY_CODE=CM
DEFAULT_CURRENCY=XAF
DEFAULT_LANGUAGE=fr

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:19006
